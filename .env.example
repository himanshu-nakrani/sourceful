# --- Shared runtime ---
# LOG_LEVEL=INFO
# RATE_LIMIT_RPM=120
# REQUEST_TIMEOUT_SECONDS=60
# MAX_CONVERSATION_HISTORY=50
# MAX_DOCUMENT_BYTES=10485760
# MAX_CHUNKS=800
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200
# CHUNK_STRATEGY=fixed                # fixed | semantic (Phase 2.2)
# CHUNK_SEMANTIC_THRESHOLD=0.5        # breakpoint similarity threshold for semantic chunking
# RAG_TOP_K=5
# ALLOWED_FILE_TYPES=.pdf,.txt,.md,.docx,.csv,.xlsx,.pptx,.html,.htm
# WORKER_POLL_INTERVAL_SECONDS=1.5
# WORKER_HEARTBEAT_TTL_SECONDS=60

# --- PostgreSQL production ---
# DATABASE_URL=postgresql://document_rag:document_rag@localhost:5432/document_rag

# --- SQLite / local dev fallback ---
# DATABASE_PATH=data/ragapp.db
# VECTOR_STORE_DIRECTORY=data/vectors
# DOCUMENT_REGISTRY_PATH=data/documents.json

# --- Defaults for provider models ---
# DEFAULT_CHAT_MODEL_OPENAI=gpt-4o-mini
# DEFAULT_CHAT_MODEL_GEMINI=gemini-2.0-flash
# DEFAULT_EMBEDDING_MODEL_OPENAI=text-embedding-3-small
# DEFAULT_EMBEDDING_MODEL_GEMINI=models/gemini-embedding-001

# --- Frontend ---
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# BACKEND_URL=http://127.0.0.1:8000
# Comma-separated. In production, include your real frontend origin(s), e.g.:
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
# Include every dev origin you use (localhost vs 127.0.0.1 and the Next.js port differ).
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# --- Retrieval feature flags (Phase 0/1, all default OFF) ---
# RETRIEVAL_HYBRID_ENABLED=false
# RETRIEVAL_RERANKER_ENABLED=false
# RETRIEVAL_CONTEXTUAL_ENABLED=false
# RETRIEVAL_GRAPH_ENABLED=false
# RETRIEVAL_AGENT_ENABLED=false

# --- Reranker (enable via RETRIEVAL_RERANKER_ENABLED=true) ---
# RERANKER_PROVIDER=cohere          # cohere | jina | bge-local | noop
# RERANKER_MODEL=rerank-english-v3.0
# RERANKER_API_KEY=...              # required for cohere / jina
# RERANKER_OVERFETCH_FACTOR=4
# RERANKER_TIMEOUT_SECONDS=10

# --- Hybrid search tuning ---
# HYBRID_FTS_WEIGHT=1.0
# HYBRID_VECTOR_WEIGHT=1.0
# HYBRID_RRF_K=60

# --- pgvector index tuning ---
# PGVECTOR_HNSW_M=16
# PGVECTOR_HNSW_EF_CONSTRUCTION=64

# --- MMR diversification (Phase 1.9) ---
# RETRIEVAL_MMR_ENABLED=false
# RETRIEVAL_MMR_LAMBDA=0.7          # 1.0=pure relevance, 0.0=pure diversity

# --- Query transformations (Phase 1.7) ---
# RETRIEVAL_QUERY_TRANSFORMS_ENABLED=false
# RETRIEVAL_QUERY_TRANSFORMS=multi_query  # comma-separated: hyde, multi_query, step_back
# RETRIEVAL_MULTI_QUERY_COUNT=3

# --- Parent-document retrieval (Phase 1.10) ---
# RETRIEVAL_PARENT_DOC_ENABLED=false
# RETRIEVAL_PARENT_WINDOW_CHARS=2400
# RETRIEVAL_CHILD_WINDOW_CHARS=600

# --- Context compression (Phase 1.11) ---
# CONTEXT_COMPRESSION_MODE=none       # none | heuristic | llmlingua
# CONTEXT_COMPRESSION_TARGET_TOKENS=2000

# --- Groundedness verifier (Phase 1.12) ---
# GROUNDEDNESS_VERIFIER_ENABLED=false
# GROUNDEDNESS_MIN_SCORE=0.5

# --- Tracing (optional; leave blank to disable) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
