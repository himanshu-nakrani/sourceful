# =============================================================================
# Document QA / DocRAG — environment template
# Copy to `.env` at the repo root (and/or `backend/.env`). Both are loaded by
# pydantic-settings. Required variables are marked REQUIRED.
# =============================================================================

# --- REQUIRED for API startup ---
DEFAULT_SUPERUSER_PASSWORD=change-me-in-production

# --- Shared runtime ---
LOG_LEVEL=INFO
SERVICE_NAME=document-rag
RATE_LIMIT_RPM=60
REQUEST_TIMEOUT_SECONDS=60
MAX_CONVERSATION_HISTORY=50
MAX_QUESTION_LENGTH=2000
MAX_MODEL_NAME_LENGTH=128
MAX_DOCUMENT_BYTES=10485760
MAX_CHUNKS=800
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
CHUNK_STRATEGY=fixed
CHUNK_SEMANTIC_THRESHOLD=0.78
RAG_TOP_K=5
ALLOWED_FILE_TYPES=.pdf,.txt,.md,.docx,.csv
WORKER_POLL_INTERVAL_SECONDS=1.5
WORKER_HEARTBEAT_TTL_SECONDS=60

# --- PostgreSQL production (recommended) ---
# DATABASE_URL=postgresql://document_rag:document_rag@localhost:5432/document_rag

# --- SQLite / local dev fallback (used when DATABASE_URL is unset) ---
DATABASE_PATH=data/ragapp.db
VECTOR_STORE_DIRECTORY=data/vectors
DOCUMENT_REGISTRY_PATH=data/documents.json

# --- Auth & sessions ---
DEFAULT_SUPERUSER_EMAIL=admin@example.com
AUTH_COOKIE_NAME=rag_session
AUTH_COOKIE_TTL_HOURS=168
AUTH_SECURE_COOKIES=false

# --- Google OAuth (optional) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Default provider models ---
DEFAULT_CHAT_MODEL_OPENAI=gpt-4o-mini
DEFAULT_CHAT_MODEL_GEMINI=gemini-2.5-flash
DEFAULT_EMBEDDING_MODEL_OPENAI=text-embedding-3-small
DEFAULT_EMBEDDING_MODEL_GEMINI=models/gemini-embedding-001
DEFAULT_CHAT_MODEL_VERTEX_SEARCH=gemini-2.5-flash
DEFAULT_EMBEDDING_MODEL_VERTEX_SEARCH=vertex_search_managed

# --- Vertex AI Search (optional managed ingest; service-side credentials) ---
VERTEX_SEARCH_PROJECT=
VERTEX_SEARCH_LOCATION=global
VERTEX_SEARCH_DATASTORE_ID=

# --- Frontend / proxy ---
# For local dev, set this so workspace & artifact API calls reach FastAPI directly.
# Next.js rewrites cover core routes; workspace routes need the backend URL or extra rewrites.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
BACKEND_URL=http://127.0.0.1:8000
# Comma-separated browser origins allowed by CORS on the API.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# --- Retrieval feature flags (all default OFF) ---
RETRIEVAL_HYBRID_ENABLED=false
RETRIEVAL_RERANKER_ENABLED=false
RETRIEVAL_CONTEXTUAL_ENABLED=false
RETRIEVAL_GRAPH_ENABLED=false
RETRIEVAL_AGENT_ENABLED=false

# --- Reranker ---
RERANKER_PROVIDER=noop
RERANKER_MODEL=rerank-english-v3.0
RERANKER_API_KEY=
RERANKER_OVERFETCH_FACTOR=4
RERANKER_TIMEOUT_SECONDS=10

# --- Hybrid search tuning (PostgreSQL + tsvector lane) ---
HYBRID_FTS_WEIGHT=1.0
HYBRID_VECTOR_WEIGHT=1.0
HYBRID_RRF_K=60

# --- pgvector HNSW index tuning ---
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64

# --- MMR diversification ---
RETRIEVAL_MMR_ENABLED=false
RETRIEVAL_MMR_LAMBDA=0.7

# --- Query transformations ---
RETRIEVAL_QUERY_TRANSFORMS_ENABLED=false
RETRIEVAL_QUERY_TRANSFORMS=multi_query
RETRIEVAL_MULTI_QUERY_COUNT=3

# --- Parent-document retrieval ---
RETRIEVAL_PARENT_DOC_ENABLED=false
RETRIEVAL_PARENT_WINDOW_CHARS=2400
RETRIEVAL_CHILD_WINDOW_CHARS=600

# --- Context compression ---
CONTEXT_COMPRESSION_MODE=none
CONTEXT_COMPRESSION_TARGET_TOKENS=2000

# --- Groundedness verifier ---
GROUNDEDNESS_VERIFIER_ENABLED=false
GROUNDEDNESS_MIN_SCORE=0.5

# --- Agentic retrieval ---
RETRIEVAL_AGENT_MAX_ITERATIONS=4
RETRIEVAL_AGENT_MAX_CHUNKS=12
RETRIEVAL_AGENT_MAX_TOOL_CALLS=8

# --- Conversation memory ---
MEMORY_ENABLED=false
MEMORY_RECENT_TURNS=6
MEMORY_SUMMARY_MAX_CHARS=1200

# --- Active-learning hint ---
ACTIVE_LEARNING_HINT_ENABLED=true
ACTIVE_LEARNING_SCORE_FLOOR=0.35

# --- GraphRAG ingestion ---
GRAPH_EXTRACT_MAX_CHUNKS=30
GRAPH_EXTRACT_MAX_CHUNK_CHARS=3500
GRAPH_EXTRACT_CONCURRENCY=4
GRAPH_COMMUNITY_MIN_SIZE=2
GRAPH_COMMUNITY_MAX_ENTITIES=20

# --- Graph traversal retrieval lane ---
RETRIEVAL_GRAPH_TRAVERSAL_ENABLED=false
RETRIEVAL_GRAPH_HOPS=1
RETRIEVAL_GRAPH_SEED_LIMIT=6
RETRIEVAL_GRAPH_CHUNK_LIMIT=10
RETRIEVAL_GRAPH_LANE_WEIGHT=0.5

# --- Tracing (optional; no-op when unset) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
