# --- Shared runtime ---
# LOG_LEVEL=INFO
# RATE_LIMIT_RPM=120
# REQUEST_TIMEOUT_SECONDS=60
# MAX_CONVERSATION_HISTORY=50
# MAX_DOCUMENT_BYTES=10485760
# MAX_CHUNKS=800
# CHUNK_SIZE=1200
# CHUNK_OVERLAP=200
# RAG_TOP_K=5
# ALLOWED_FILE_TYPES=.pdf,.txt,.md,.docx,.csv
# WORKER_POLL_INTERVAL_SECONDS=1.5
# WORKER_HEARTBEAT_TTL_SECONDS=60

# --- PostgreSQL production ---
# DATABASE_URL=postgresql://document_rag:document_rag@localhost:5432/document_rag

# --- SQLite / local dev fallback ---
# DATABASE_PATH=data/ragapp.db
# VECTOR_STORE_DIRECTORY=data/vectors
# DOCUMENT_REGISTRY_PATH=data/documents.json

# --- Defaults for provider models ---
# DEFAULT_CHAT_MODEL_OPENAI=gpt-4o-mini
# DEFAULT_CHAT_MODEL_GEMINI=gemini-2.0-flash
# DEFAULT_EMBEDDING_MODEL_OPENAI=text-embedding-3-small
# DEFAULT_EMBEDDING_MODEL_GEMINI=models/gemini-embedding-001

# --- Frontend ---
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# BACKEND_URL=http://127.0.0.1:8000
# Comma-separated. In production, include your real frontend origin(s), e.g.:
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
