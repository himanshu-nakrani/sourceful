# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# Python (legacy Streamlit in /legacy)
__pycache__/
*.py[cod]
.venv/
venv/

# Streamlit
.streamlit/secrets.toml

# RAG / vectors / registry
/data/
node_output.log
pnpm_output.log

# local-only drafts
docs/launch-posts.md
